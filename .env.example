# EC2 + Docker 部署用。复制为 .env 后填写实际值。
# 一键启动：docker compose up -d --build

# ---------- 数据库（必填：你的 RDS 连接串）----------
DATABASE_URL=postgresql://用户名:密码@你的RDS端点:5432/数据库名

# ---------- 后端 ----------
JWT_SECRET=请改成随机长字符串
JWT_EXPIRES_IN=7d

# ---------- 前端请求的后端地址（必填：浏览器访问的 API 地址）----------
# 若 EC2 公网 IP 为 3.1.2.3，则填 http://3.1.2.3:3001/api
NEXT_PUBLIC_API_URL=http://你的EC2公网IP或域名:3001/api

# ---------- 后端 CORS：允许的前端来源 ----------
# 若前端通过 http://3.1.2.3:3000 访问，则填 http://3.1.2.3:3000
CORS_ORIGIN=http://你的EC2公网IP或域名:3000
