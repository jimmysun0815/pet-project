# 复制为 .env 后按需修改。
# ---------- 数据库 ----------
# 宿主机跑 migrate/seed 时用（连 localhost:5432）
DATABASE_URL=postgresql://app:app@localhost:5432/pet_booking

# Docker 里 backend 连的库：本地/EC2 用 compose 的 postgres 时填下面这行；用 RDS 时改成 RDS 连接串并加 ?sslmode=require
BACKEND_DATABASE_URL=postgresql://app:app@postgres:5432/pet_booking

# ---------- 后端 ----------
JWT_SECRET=dev-jwt-secret
JWT_EXPIRES_IN=7d

# ---------- 前端与 CORS ----------
# 本地：localhost。EC2 部署时必改：填 EC2 公网 IP，如 http://35.164.218.25:3001/api（改完需重建 frontend）
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# 本地：可不改。EC2 必改：填用户访问前端的地址（80 端口不写），如 http://35.164.218.25，否则会 CORS 报错 / Failed to fetch
CORS_ORIGIN=http://localhost,http://localhost:3000
