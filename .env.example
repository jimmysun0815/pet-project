# 复制为 .env 后按需修改。本地 demo 可不填，直接用 compose 里的 postgres。

# ---------- 数据库 ----------
# 不填则用 Docker 里的 postgres（本地 demo）。用 RDS 时再填，RDS 需加 ?sslmode=require
# DATABASE_URL=postgresql://app:app@postgres:5432/pet_booking
# DATABASE_URL=postgresql://用户:密码@RDS端点:5432/库名?sslmode=require

# ---------- 后端 ----------
JWT_SECRET=dev-jwt-secret
JWT_EXPIRES_IN=7d

# ---------- 前端与 CORS（本地可不改）----------
NEXT_PUBLIC_API_URL=http://localhost:3001/api
CORS_ORIGIN=http://localhost:3000
